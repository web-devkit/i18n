{
  "compilerOptions": {
    "target": "es2021",
    "module": "es2015",
    "moduleResolution": "bundler",
    "lib": ["es2021", "dom"],
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
